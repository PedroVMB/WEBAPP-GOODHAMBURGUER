@page "/orders"
@using GoodHamburguer.Application.DTOs
@using GoodHamburguer.Model.Enums
@using GoodHamburguer.Web.Services
@inject IOrderApiService ApiService
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Pedidos — Good Hamburger</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">📋 Pedidos</h1>
    @if (!_showForm)
    {
        <button class="btn btn-success" @onclick="ShowCreateForm">+ Novo Pedido</button>
    }
</div>

@if (_showForm)
{
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white fw-bold">
            @(_editingId.HasValue ? "✏️ Editar Pedido" : "➕ Novo Pedido")
        </div>
        <div class="card-body">
            <OrderForm Model="_formModel"
                       Errors="_formErrors"
                       SubmitLabel="@(_editingId.HasValue ? "Atualizar" : "Criar")"
                       OnSubmit="HandleFormSubmit"
                       OnCancel="CancelForm" />
        </div>
    </div>
}

@if (_successMessage is not null)
{
    <div class="alert alert-success alert-dismissible fade show">
        ✅ @_successMessage
        <button type="button" class="btn-close" @onclick="() => _successMessage = null"></button>
    </div>
}

@if (_connectionError)
{
    <div class="alert alert-danger">
        <strong>Não foi possível conectar à API.</strong> Verifique se a API está em execução em <code>http://localhost:5066</code>.
        <br/>
        <button class="btn btn-sm btn-outline-danger mt-2" @onclick="RetryLoad">Tentar novamente</button>
    </div>
}
else if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2 text-muted">Carregando pedidos...</p>
    </div>
}
else if (!_orders.Any())
{
    <div class="text-center py-5">
        <div style="font-size:3rem">🛒</div>
        <p class="text-muted mt-2">Nenhum pedido encontrado. Que tal criar o primeiro?</p>
        <button class="btn btn-success" @onclick="ShowCreateForm">+ Novo Pedido</button>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var order in _orders)
        {
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <span class="badge bg-secondary fs-6">#@order.Id</span>
                            </div>
                            <div class="col">
                                <div class="d-flex flex-wrap gap-2 align-items-center">
                                    <span class="badge bg-warning text-dark">🍔 @order.Sandwich</span>
                                    @if (order.Fries is not null)
                                    {
                                        <span class="badge bg-warning text-dark">🍟 Batata</span>
                                    }
                                    @if (order.Soda is not null)
                                    {
                                        <span class="badge bg-warning text-dark">🥤 Refrigerante</span>
                                    }
                                </div>
                            </div>
                            <div class="col-auto text-end">
                                <div class="text-muted small">Subtotal: R$ @order.Subtotal.ToString("F2")</div>
                                @if (order.DiscountPercent > 0)
                                {
                                    <div class="text-success small">Desconto: @order.DiscountPercent% (−R$ @order.DiscountAmount.ToString("F2"))</div>
                                }
                                <div class="fw-bold fs-5">R$ @order.Total.ToString("F2")</div>
                            </div>
                            <div class="col-auto">
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ShowEditForm(order)" title="Editar">✏️</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(order.Id)" title="Excluir">🗑️</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="card mt-4 bg-light border-0">
        <div class="card-body d-flex justify-content-between">
            <span class="fw-bold">Total de pedidos: @_orders.Count</span>
            <span class="fw-bold text-success">Total geral: R$ @_orders.Sum(o => o.Total).ToString("F2")</span>
        </div>
    </div>
}

@if (_confirmDeleteId.HasValue)
{
    <div class="modal fade show d-block" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar exclusão</h5>
                </div>
                <div class="modal-body">
                    Deseja excluir o pedido <strong>#@_confirmDeleteId</strong>?
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _confirmDeleteId = null">Cancelar</button>
                    <button class="btn btn-danger" @onclick="ExecuteDelete">Excluir</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _connectionError = false;
    private bool _showForm = false;
    private int? _editingId;
    private int? _confirmDeleteId;
    private List<OrderResponse> _orders = [];
    private CreateOrderRequest _formModel = new();
    private IEnumerable<string>? _formErrors;
    private string? _successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        _loading = true;
        _connectionError = false;
        try
        {
            _orders = (await ApiService.GetAllOrdersAsync()).ToList();
        }
        catch (HttpRequestException)
        {
            _connectionError = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RetryLoad()
    {
        await LoadOrders();
    }

    private void ShowCreateForm()
    {
        _formModel = new CreateOrderRequest();
        _editingId = null;
        _formErrors = null;
        _showForm = true;
    }

    private void ShowEditForm(OrderResponse order)
    {
        _editingId = order.Id;
        _formModel = new CreateOrderRequest
        {
            Sandwich = order.Sandwich switch
            {
                "X-Burger" => SandwichType.XBurger,
                "X-Egg" => SandwichType.XEgg,
                "X-Bacon" => SandwichType.XBacon,
                _ => null
            },
            IncludeFries = order.Fries is not null,
            IncludeSoda = order.Soda is not null
        };
        _formErrors = null;
        _showForm = true;
    }

    private void CancelForm()
    {
        _showForm = false;
        _editingId = null;
        _formErrors = null;
    }

    private async Task HandleFormSubmit()
    {
        _formErrors = null;

        if (_editingId.HasValue)
        {
            var updateRequest = new UpdateOrderRequest
            {
                Sandwich = _formModel.Sandwich,
                IncludeFries = _formModel.IncludeFries,
                IncludeSoda = _formModel.IncludeSoda
            };
            var (result, error) = await ApiService.UpdateOrderAsync(_editingId.Value, updateRequest);
            if (error is not null)
            {
                _formErrors = error.Errors.Any() ? error.Errors : [error.Message];
                return;
            }
            _successMessage = $"Pedido #{result!.Id} atualizado com sucesso.";
        }
        else
        {
            var (result, error) = await ApiService.CreateOrderAsync(_formModel);
            if (error is not null)
            {
                _formErrors = error.Errors.Any() ? error.Errors : [error.Message];
                return;
            }
            _successMessage = $"Pedido #{result!.Id} criado com sucesso.";
        }

        _showForm = false;
        _editingId = null;
        await LoadOrders();
    }

    private void ConfirmDelete(int id)
    {
        _confirmDeleteId = id;
    }

    private async Task ExecuteDelete()
    {
        if (_confirmDeleteId is null) return;
        var id = _confirmDeleteId.Value;
        _confirmDeleteId = null;

        var error = await ApiService.DeleteOrderAsync(id);
        if (error is null)
            _successMessage = $"Pedido #{id} excluído.";

        await LoadOrders();
    }
}
